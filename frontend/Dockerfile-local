FROM node:22.17.0-alpine

# node:alpine вже містить user 'node' (UID 1000) — використовуємо його.
# Це запобігає EACCES: node_modules, записані контейнером, залишаються читабельними на хості.

WORKDIR /usr/app
RUN chown node:node /usr/app

USER node

COPY --chown=node:node package*.json ./
RUN npm install

EXPOSE 3000
CMD ["npm", "run", "dev"]
